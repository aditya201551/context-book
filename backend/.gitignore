# ============================================================
# Go Backend — workspace-level .gitignore
# The root .gitignore handles monorepo-wide patterns.
# This file covers Go-specific artifacts local to /backend.
# ============================================================

# Compiled binary output
bin/

# Go test binary & coverage artifacts
*.test
*.out
coverage.txt
coverage.html

# Go workspace sum (auto-generated by `go work sync`)
go.work.sum

# Air live-reload temp directory
tmp/

# Build cache (should use GOCACHE env, not local dir)
.cache/

# Profiling output
*.prof
cpu.prof
mem.prof
