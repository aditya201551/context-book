# ==========================================
# ContextBridge Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values.
# Variables are grouped by: BACKEND | FRONTEND
# ==========================================

# ──────────────────────────────────────────
# BACKEND
# ──────────────────────────────────────────

# Server ports
PORT=8080
MCP_PORT=8081
ENV=development

# Database Settings (Postgres 16+ with pgvector extension)
DATABASE_URL=postgres://user:pass@localhost:5432/dbname

# Embeddings Provider — get a key at https://voyageai.com
VOYAGE_API_KEY=your-voyageai-api-key-here
VOYAGE_MODEL=voyage-4
VOYAGE_DIMENSION=1024

# Auth Configuration — generate a long random string
API_KEY_SALT=generate-a-long-random-string

# OAuth2 — Google (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2 — GitHub (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Session / Cookies
# COOKIE_DOMAIN=.yourdomain.com

# Public URLs (used for OAuth discovery and redirects)
PUBLIC_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

# Production overrides (uncomment for custom domains):
# PUBLIC_URL=https://api.yourdomain.com
# FRONTEND_URL=https://ui.yourdomain.com

# ──────────────────────────────────────────
# FRONTEND
# ──────────────────────────────────────────

# Backend API base URL (leave empty to use same-origin /api)
VITE_API_URL=
VITE_MCP_URL=http://localhost:8081/mcp

# Production override (uncomment for custom domain):
# VITE_API_URL=https://api.yourdomain.com
# VITE_MCP_URL=https://api.yourdomain.com/mcp
