# syntax=docker/dockerfile:1

# ==========================================
# ContextBridge — MCP Server Dockerfile
# ==========================================
# This Dockerfile builds ONLY the MCP server.
# Use it for the "mcp" Railway service.
# ==========================================

# ─── Stage 1: Build MCP binary ───
FROM golang:1.24-alpine AS go-builder
WORKDIR /app
RUN apk add --no-cache git ca-certificates

ENV GOTOOLCHAIN=auto

COPY backend/go.mod backend/go.sum ./
RUN go mod download

COPY backend/ ./
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o bin/mcp ./cmd/mcp/main.go

# ─── Stage 2: Production image ───
FROM gcr.io/distroless/static-debian12
WORKDIR /app
COPY --from=go-builder /app/bin/mcp /app/mcp
ENV MCP_PORT=8080
EXPOSE 8080
ENTRYPOINT ["/app/mcp"]
